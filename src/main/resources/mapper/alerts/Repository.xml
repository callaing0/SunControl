<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.suncontrol.mapper.Repository">

    <resultMap id="AlertMap" type="com.suncontrol.domain.dto.AlertResponseDTO">
        <id property="id" column="id" />
        <result property="inverterId" column="inverter_id" />
        <result property="status" column="status" typeHandler="org.apache.ibatis.type.EnumOrdinalTypeHandler" />
        <result property="createdAt" column="created_at" />
        <result property="checkedAt" column="checked_at" />
        <result property="resolvedAt" column="resolved_at" />
    </resultMap>

    <select id="findAll" resultMap="AlertMap">
        SELECT * FROM alert_log ORDER BY created_at DESC
    </select>

    <select id="findById" resultType="com.suncontrol.core.entity.log.AlertLog">
        SELECT * FROM alert_log WHERE id = #{id}
    </select>

    <update id="updateAlertProcess">
        UPDATE alert_log
        SET
            status = #{status},
            checked_at = #{checkedAt},
            resolved_at = #{resolvedAt}
        WHERE id = #{id}
    </update>
</mapper>