<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.suncontrol.mapper.Repository">

    <resultMap id="AlertMap" type="com.suncontrol.domain.dto.AlertResponseDTO">
        <id property="id" column="id" />
        <result property="inverterId" column="inverter_id" />
        <result property="location" column="inverter_id" /> <result property="status" column="status"
                                                                    typeHandler="org.apache.ibatis.type.EnumOrdinalTypeHandler" />
        <result property="alertType" column="alert_type" />
        <result property="severity" column="severity" />
        <result property="message" column="message" />
        <result property="createdAt" column="created_at" />
        <result property="resolvedAt" column="resolved_at" />
        <result property="durationSeconds" column="duration_seconds" />
    </resultMap>

    <select id="findAll" resultMap="AlertMap">
        SELECT * FROM alert_log ORDER BY created_at DESC
    </select>

    <update id="updateStatus">
        UPDATE alert_log
        SET
            status = #{status},
            resolved_at = CASE WHEN #{status} = 2 THEN NOW() ELSE resolved_at END,
            duration_seconds = CASE
                                   WHEN #{status} = 2 THEN TIMESTAMPDIFF(SECOND, created_at, NOW())
                                   ELSE duration_seconds
                END
        WHERE id = #{id}
    </update>

</mapper>